{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://up2date.dev/schemas/mqtt-node-snapshot.schema.json",
  "title": "up2date MQTT node snapshot",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "agent_id",
    "observed_at",
    "services"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "docker_node_snapshot"
    },
    "agent_id": {
      "type": "string"
    },
    "node_name": {
      "type": "string"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "container_id",
          "container_name",
          "service_name",
          "image",
          "detected_version",
          "detected_version_source",
          "state",
          "running",
          "observed_via"
        ],
        "properties": {
          "container_id": {
            "type": "string"
          },
          "container_name": {
            "type": "string"
          },
          "service_name": {
            "type": "string"
          },
          "project_name": {
            "type": "string"
          },
          "image": {
            "type": "string"
          },
          "image_name": {
            "type": "string"
          },
          "image_tag": {
            "type": "string"
          },
          "detected_version": {
            "type": "string"
          },
          "detected_version_source": {
            "type": "string",
            "enum": [
              "container_label",
              "image_tag",
              "unknown"
            ]
          },
          "version_label_key": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "running": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "observed_via": {
            "type": "string",
            "const": "docker_engine"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
