{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://up2date.dev/schemas/service-check.schema.json",
  "title": "up2date service check",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "node_id",
    "service_name",
    "observed_at",
    "current_version",
    "status",
    "update_available"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "const": "service_check"
    },
    "node_id": {
      "type": "string"
    },
    "node_name": {
      "type": "string"
    },
    "service_name": {
      "type": "string"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "image_name": {
      "type": "string"
    },
    "current_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "latest_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "current",
        "outdated",
        "unknown",
        "unsupported",
        "error"
      ]
    },
    "update_available": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "reason": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
